{
  "$defs": {
    "CollectionStatus": {
      "enum": [
        "completed",
        "partial_done",
        "degraded",
        "failed"
      ],
      "title": "CollectionStatus",
      "type": "string"
    },
    "Evidence": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/EvidenceSource"
        },
        "evidence_type": {
          "title": "Evidence Type",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        },
        "related_entities": {
          "items": {
            "type": "string"
          },
          "title": "Related Entities",
          "type": "array"
        },
        "source_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "raw_data": {
          "additionalProperties": true,
          "title": "Raw Data",
          "type": "object"
        },
        "mitre_technique": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mitre Technique"
        },
        "is_conflicting": {
          "default": false,
          "title": "Is Conflicting",
          "type": "boolean"
        }
      },
      "required": [
        "evidence_id",
        "event_id",
        "source",
        "evidence_type",
        "description",
        "confidence"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "EvidenceConflict": {
      "additionalProperties": false,
      "description": "A detected contradiction between two or more pieces of evidence.",
      "properties": {
        "conflict_id": {
          "title": "Conflict Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Sources",
          "type": "array"
        },
        "detail": {
          "additionalProperties": true,
          "title": "Detail",
          "type": "object"
        }
      },
      "required": [
        "conflict_id",
        "event_id",
        "description"
      ],
      "title": "EvidenceConflict",
      "type": "object"
    },
    "EvidenceGap": {
      "additionalProperties": false,
      "description": "A required evidence source that could not be collected.",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "missing_source": {
          "$ref": "#/$defs/EvidenceSource"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "detail": {
          "additionalProperties": true,
          "title": "Detail",
          "type": "object"
        }
      },
      "required": [
        "event_id",
        "missing_source",
        "reason"
      ],
      "title": "EvidenceGap",
      "type": "object"
    },
    "EvidenceOutput": {
      "additionalProperties": false,
      "properties": {
        "evidence_list": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "title": "Evidence List",
          "type": "array"
        },
        "conflicts": {
          "items": {
            "$ref": "#/$defs/EvidenceConflict"
          },
          "title": "Conflicts",
          "type": "array"
        },
        "gaps": {
          "items": {
            "$ref": "#/$defs/EvidenceGap"
          },
          "title": "Gaps",
          "type": "array"
        },
        "success_sources": {
          "items": {
            "type": "string"
          },
          "title": "Success Sources",
          "type": "array"
        },
        "failed_sources": {
          "items": {
            "type": "string"
          },
          "title": "Failed Sources",
          "type": "array"
        },
        "overall_confidence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Overall Confidence",
          "type": "number"
        },
        "collection_status": {
          "$ref": "#/$defs/CollectionStatus"
        }
      },
      "required": [
        "collection_status"
      ],
      "title": "EvidenceOutput",
      "type": "object"
    },
    "EvidenceSource": {
      "description": "Eight evidence sources.",
      "enum": [
        "identity",
        "endpoint",
        "data_security",
        "network_flow",
        "dns",
        "asset",
        "threat_intel",
        "false_positive_match"
      ],
      "title": "EvidenceSource",
      "type": "string"
    },
    "RiskAssessment": {
      "additionalProperties": false,
      "properties": {
        "risk_score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Risk Score",
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "risk_factors": {
          "items": {
            "$ref": "#/$defs/RiskFactor"
          },
          "title": "Risk Factors",
          "type": "array"
        },
        "possible_false_positive": {
          "default": false,
          "title": "Possible False Positive",
          "type": "boolean"
        },
        "scoring_mode": {
          "$ref": "#/$defs/ScoringMode"
        }
      },
      "required": [
        "risk_score",
        "severity",
        "confidence",
        "scoring_mode"
      ],
      "title": "RiskAssessment",
      "type": "object"
    },
    "RiskFactor": {
      "additionalProperties": false,
      "properties": {
        "factor_name": {
          "title": "Factor Name",
          "type": "string"
        },
        "weight": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Weight",
          "type": "number"
        },
        "raw_score": {
          "title": "Raw Score",
          "type": "number"
        },
        "weighted_score": {
          "title": "Weighted Score",
          "type": "number"
        },
        "reasoning": {
          "default": "",
          "title": "Reasoning",
          "type": "string"
        }
      },
      "required": [
        "factor_name",
        "weight",
        "raw_score",
        "weighted_score"
      ],
      "title": "RiskFactor",
      "type": "object"
    },
    "ScoringMode": {
      "enum": [
        "llm_and_rule",
        "rule_only"
      ],
      "title": "ScoringMode",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceDisposition": {
      "description": "Normalized external disposition label; source_status_raw keeps the original.",
      "enum": [
        "pending",
        "processing",
        "contained",
        "completed",
        "suspended",
        "ignored",
        "unknown"
      ],
      "title": "SourceDisposition",
      "type": "string"
    },
    "SourceObjectKind": {
      "description": "Canonical source object kind used for the internal discriminated union.",
      "enum": [
        "incident",
        "alert",
        "asset",
        "log",
        "connector"
      ],
      "title": "SourceObjectKind",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "description": "Immutable snapshot reference to an external source object (intro §4.3).\n\nIdentity five-tuple is\n``(source_product, source_tenant_id, connector_id, source_kind, source_object_id)``.\nThe adapter-native ``source_object_type`` and opaque ``source_concurrency_token``\ndo NOT participate in identity.",
      "properties": {
        "source_kind": {
          "$ref": "#/$defs/SourceObjectKind"
        },
        "source_product": {
          "title": "Source Product",
          "type": "string"
        },
        "source_tenant_id": {
          "title": "Source Tenant Id",
          "type": "string"
        },
        "connector_id": {
          "title": "Connector Id",
          "type": "string"
        },
        "source_object_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Object Type"
        },
        "source_object_id": {
          "title": "Source Object Id",
          "type": "string"
        },
        "parent_source_object_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Source Object Id"
        },
        "source_status_raw": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Status Raw"
        },
        "source_disposition": {
          "$ref": "#/$defs/SourceDisposition",
          "default": "unknown"
        },
        "source_concurrency_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Concurrency Token"
        },
        "source_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Updated At"
        },
        "schema_version": {
          "default": "1",
          "title": "Schema Version",
          "type": "string"
        },
        "ingested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ingested At"
        },
        "raw_payload_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Payload Hash"
        }
      },
      "required": [
        "source_kind",
        "source_product",
        "source_tenant_id",
        "connector_id",
        "source_object_id"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "risk_assessment": {
      "$ref": "#/$defs/RiskAssessment"
    },
    "evidence_output": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidenceOutput"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "event_id",
    "risk_assessment"
  ],
  "title": "ResponseAgentInput",
  "type": "object"
}
