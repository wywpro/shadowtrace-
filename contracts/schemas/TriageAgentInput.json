        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
