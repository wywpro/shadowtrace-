{
  "$defs": {
    "AccountEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "account",
          "default": "account",
          "title": "Entity Type",
          "type": "string"
        },
        "username": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Username"
        },
        "domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Domain"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "AccountEntity",
      "type": "object"
    },
    "DomainEntity": {
