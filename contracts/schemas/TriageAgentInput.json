        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "host",
          "default": "host",
          "title": "Entity Type",
          "type": "string"
        },
        "hostname": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hostname"
        },
        "ip": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ip"
        },
        "os": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Os"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "HostEntity",
