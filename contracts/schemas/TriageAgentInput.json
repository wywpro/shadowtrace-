        "entity_type": {
          "const": "domain",
          "default": "domain",
          "title": "Entity Type",
          "type": "string"
        },
        "fqdn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fqdn"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "DomainEntity",
      "type": "object"
    },
    "EntitySet": {
