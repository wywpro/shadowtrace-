        },
        "domains": {
          "items": {
            "$ref": "#/$defs/DomainEntity"
          },
          "title": "Domains",
          "type": "array"
        },
        "processes": {
          "items": {
            "$ref": "#/$defs/ProcessEntity"
          },
          "title": "Processes",
          "type": "array"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/FileEntity"
          },
          "title": "Files",
          "type": "array"
        }
      },
      "title": "EntitySet",
      "type": "object"
