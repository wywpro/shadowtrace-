      },
      "required": [
        "job_id",
        "event_id",
        "action_id",
        "provider_name",
        "idempotency_key"
      ],
      "title": "ActionExecutionJob",
      "type": "object"
    },
    "ActionExecutionPhase": {
      "enum": [
        "immediate",
        "post_verify"
      ],
      "title": "ActionExecutionPhase",
      "type": "string"
    },
    "ActionStatus": {
      "description": "Action lifecycle state (11 states).",
      "enum": [
        "pending",
        "waiting_approval",
        "approved",
        "rejected",
        "superseded",
        "executing",
        "partial_success",
        "success",
        "failed",
        "unknown",
        "rolled_back"
      ],
      "title": "ActionStatus",
      "type": "string"
    },
    "ConfirmationEvidence": {
      "enum": [
        "adapter_acknowledged",
        "status_queried",
        "readback_verified",
        "manual_confirmed"
      ],
      "title": "ConfirmationEvidence",
      "type": "string"
    },
    "DispositionCommand": {
      "additionalProperties": false,
      "description": "Minimal outbound disposition envelope (strict allowlist).",
      "properties": {
        "disposition_id": {
          "title": "Disposition Id",
          "type": "string"
        },
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "closure_cycle": {
          "title": "Closure Cycle",
          "type": "integer"
        },
        "intent_kind": {
          "$ref": "#/$defs/DispositionIntentKind"
        },
        "source_locator": {
          "$ref": "#/$defs/SourceObjectLocator"
        },
        "operation_code": {
          "title": "Operation Code",
          "type": "string"
        },
        "operation_params": {
          "discriminator": {
            "mapping": {
              "record_compensation": "#/$defs/RecordCompensationParams",
              "record_execution_result": "#/$defs/RecordExecutionResultParams",
              "set_event_disposition": "#/$defs/SetEventDispositionParams",
              "submit_entity_action": "#/$defs/SubmitEntityActionParams"
            },
            "propertyName": "operation_code"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/SetEventDispositionParams"
            },
            {
              "$ref": "#/$defs/SubmitEntityActionParams"
            },
            {
              "$ref": "#/$defs/RecordExecutionResultParams"
            },
            {
              "$ref": "#/$defs/RecordCompensationParams"
            }
          ],
          "title": "Operation Params"
        },
        "target_results": {
          "items": {
            "$ref": "#/$defs/TargetDispositionResult"
          },
          "title": "Target Results",
          "type": "array"
        },
        "operator_id": {
          "title": "Operator Id",
          "type": "string"
        },
        "idempotency_key": {
          "title": "Idempotency Key",
          "type": "string"
        },
        "source_concurrency_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Concurrency Token"
        },
        "execution_owner": {
          "$ref": "#/$defs/ExecutionOwner"
        },
        "parent_disposition_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Disposition Id"
        },
        "supersedes_disposition_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Supersedes Disposition Id"
        }
      },
      "required": [
        "disposition_id",
        "action_id",
        "closure_cycle",
        "intent_kind",
        "source_locator",
        "operation_code",
        "operation_params",
        "operator_id",
        "idempotency_key",
        "execution_owner"
      ],
      "title": "DispositionCommand",
      "type": "object"
    },
    "DispositionIntentKind": {
      "description": "Internal envelope classification; not a vendor enum.",
      "enum": [
        "entity_action_submit",
        "execution_result_record",
        "compensation_record",
        "event_status_update"
      ],
      "title": "DispositionIntentKind",
      "type": "string"
    },
    "DispositionPolicy": {
      "enum": [
        "required",
        "not_required"
      ],
      "title": "DispositionPolicy",
      "type": "string"
    },
    "DispositionReceipt": {
      "additionalProperties": false,
      "description": "Append-only receipt keyed by ``(writeback_id, sequence)``; latest = max seq.",
      "properties": {
        "writeback_id": {
          "title": "Writeback Id",
          "type": "string"
        },
        "sequence": {
          "title": "Sequence",
          "type": "integer"
        },
        "disposition_id": {
          "title": "Disposition Id",
          "type": "string"
        },
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "source_record_id": {
          "title": "Source Record Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/WritebackStatus"
        },
        "confirmation_evidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConfirmationEvidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "provider_record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Record Id"
        },
        "provider_job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Job Id"
        },
        "provider_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Code"
        },
        "provider_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Message"
        },
        "observed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At"
        },
        "submitted_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Submitted At"
        },
        "confirmed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confirmed At"
        },
        "target_results": {
          "items": {
            "$ref": "#/$defs/TargetWritebackResult"
          },
          "title": "Target Results",
          "type": "array"
        },
        "raw_result": {
          "additionalProperties": true,
          "title": "Raw Result",
          "type": "object"
        },
        "truncated": {
          "default": false,
          "title": "Truncated",
          "type": "boolean"
        },
        "simulated": {
          "default": false,
          "title": "Simulated",
          "type": "boolean"
        }
      },
      "required": [
        "writeback_id",
        "sequence",
        "disposition_id",
        "action_id",
        "source_record_id",
        "status"
      ],
      "title": "DispositionReceipt",
      "type": "object"
    },
    "EventStatus": {
      "description": "ShadowTrace internal investigation orchestration state (14 states).",
      "enum": [
        "new",
        "triaging",
        "collecting_evidence",
        "analyzing",
        "scoring",
        "planning_response",
        "waiting_approval",
        "executing_response",
        "verifying",
        "replanning",
        "contained",
        "failed",
        "reporting",
        "closed"
      ],
      "title": "EventStatus",
      "type": "string"
    },
    "EventSummary": {
      "additionalProperties": false,
      "description": "The authoritative shape of ``EventContext.event`` (ISSUE-094 §2).",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "event_type": {
          "$ref": "#/$defs/EventType"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/EventStatus"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "risk_score": {
          "title": "Risk Score",
          "type": "integer"
        },
        "final_verdict": {
          "$ref": "#/$defs/FinalVerdict"
        },
        "writeback_required": {
          "title": "Writeback Required",
