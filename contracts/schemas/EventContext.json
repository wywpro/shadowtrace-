        "job_id": {
          "title": "Job Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "provider_name": {
          "title": "Provider Name",
          "type": "string"
        },
        "idempotency_key": {
          "title": "Idempotency Key",
          "type": "string"
        },
        "provider_job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Job Id"
        },
        "status": {
          "$ref": "#/$defs/ExecutionJobStatus",
