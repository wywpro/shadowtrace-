        },
        "summary_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary Code"
        }
      },
      "title": "RecordCompensationParams",
      "type": "object"
    },
    "RecordExecutionResultParams": {
      "additionalProperties": false,
      "description": "Params for EXECUTION_RESULT_RECORD (DIRECT_TOOL result sync).",
      "properties": {
        "operation_code": {
          "const": "record_execution_result",
          "default": "record_execution_result",
          "title": "Operation Code",
          "type": "string"
        },
        "summary_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary Code"
        }
      },
      "title": "RecordExecutionResultParams",
      "type": "object"
    },
    "ReportSection": {
      "additionalProperties": false,
      "description": "One chapter of the structured report.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "content": {
          "default": "",
