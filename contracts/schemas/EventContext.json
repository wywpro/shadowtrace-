        "provider_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Code"
        },
        "provider_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Message"
        },
        "raw_result": {
          "additionalProperties": true,
          "title": "Raw Result",
          "type": "object"
