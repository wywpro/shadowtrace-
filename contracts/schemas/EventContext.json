      "title": "EventSummary",
      "type": "object"
    },
    "EventType": {
      "description": "Supported security event types (intro §1); extensible via scenario packs.",
      "enum": [
        "account_anomaly",
        "host_compromise",
        "data_exfiltration",
        "insider_threat",
        "malicious_process",
        "suspicious_domain",
        "lateral_movement",
        "other"
      ],
      "title": "EventType",
      "type": "string"
    },
    "ExecutionActionView": {
      "additionalProperties": false,
      "description": "Per-action projection used inside ExecutionSummary.",
      "properties": {
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "action_status": {
          "$ref": "#/$defs/ActionStatus"
        },
        "execution_phase": {
          "$ref": "#/$defs/ActionExecutionPhase"
        },
        "writeback_required": {
          "title": "Writeback Required",
          "type": "boolean"
        },
        "writeback_applicable": {
          "title": "Writeback Applicable",
          "type": "boolean"
        },
        "writeback_readiness": {
          "$ref": "#/$defs/WritebackReadiness"
        },
        "writeback_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/WritebackStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "target_results": {
          "items": {
            "$ref": "#/$defs/TargetExecutionResult"
          },
          "title": "Target Results",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "action_status",
        "execution_phase",
        "writeback_required",
        "writeback_applicable",
        "writeback_readiness"
      ],
      "title": "ExecutionActionView",
      "type": "object"
    },
    "ExecutionJobStatus": {
      "enum": [
        "queued",
        "running",
        "partial_success",
        "success",
        "failed",
        "timed_out",
        "cancelled",
        "unknown"
      ],
      "title": "ExecutionJobStatus",
      "type": "string"
    },
    "ExecutionOwner": {
      "enum": [
        "xdr_managed",
        "direct_tool"
      ],
      "title": "ExecutionOwner",
      "type": "string"
    },
    "ExecutionSubstate": {
      "description": "Resumable checkpoint substate; never replaces EventStatus.",
      "enum": [
        "none",
        "waiting_approval",
        "waiting_execution",
        "waiting_writeback",
        "manual_resolution"
      ],
      "title": "ExecutionSubstate",
      "type": "string"
    },
    "ExecutionSummary": {
      "additionalProperties": false,
      "description": "Single source of truth reused by API / Verify / UI / CLOSED gate / stats.",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "plan_revision": {
          "title": "Plan Revision",
          "type": "integer"
        },
        "action_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Action Counts",
          "type": "object"
        },
        "jobs": {
          "items": {
            "$ref": "#/$defs/ActionExecutionJob"
          },
          "title": "Jobs",
          "type": "array"
        },
        "actions": {
          "items": {
            "$ref": "#/$defs/ExecutionActionView"
          },
          "title": "Actions",
          "type": "array"
        },
        "writeback_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/WritebackSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        }
      },
      "required": [
        "event_id",
        "plan_revision"
      ],
      "title": "ExecutionSummary",
      "type": "object"
    },
    "FinalVerdict": {
      "description": "Verdict label, independent from EventStatus.",
      "enum": [
        "none",
        "possible_false_positive",
        "false_positive",
        "confirmed_threat"
      ],
      "title": "FinalVerdict",
      "type": "string"
    },
    "ImpactAssessment": {
      "additionalProperties": false,
      "description": "Estimated blast radius / reversibility of an action (detailed in ISSUE-079).",
      "properties": {
        "impact_level": {
          "$ref": "#/$defs/Severity",
          "default": "low"
        },
        "reversible": {
          "default": true,
          "title": "Reversible",
          "type": "boolean"
        },
        "affected_entity_count": {
          "default": 0,
          "title": "Affected Entity Count",
          "type": "integer"
        },
        "affected_targets": {
          "items": {
            "type": "string"
          },
          "title": "Affected Targets",
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "assessed_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assessed By"
        }
      },
      "title": "ImpactAssessment",
      "type": "object"
    },
    "InvestigationReport": {
      "additionalProperties": false,
      "properties": {
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "sections": {
          "items": {
            "$ref": "#/$defs/ReportSection"
          },
          "title": "Sections",
          "type": "array"
        },
        "final_verdict": {
          "$ref": "#/$defs/FinalVerdict",
          "default": "none"
        },
        "risk_score": {
          "default": 0,
          "maximum": 100,
          "minimum": 0,
          "title": "Risk Score",
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "low"
        },
        "version": {
          "default": 1,
          "title": "Version",
          "type": "integer"
        },
        "generated_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
